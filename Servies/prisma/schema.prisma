// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


// ─── Users ────────────────────────────────────────────────────────────────────
model User {
  id           Int       @id @default(autoincrement())
  name         String    @db.VarChar(120)
  email        String    @unique @db.VarChar(200)
  phone        String?   @db.VarChar(20)
  passwordHash String    @map("password_hash")
  role         String    @default("customer") @db.VarChar(20) // 'customer' | 'admin'
  avatarUrl    String?   @map("avatar_url")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  cartItems           CartItem[]
  orders              Order[]
  addresses           Address[]
  wishlist            Wishlist[]
  reviews             Review[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

// ─── Password Reset Tokens ────────────────────────────────────────────────────
model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// ─── Categories ───────────────────────────────────────────────────────────────
model Category {
  id        Int        @id @default(autoincrement())
  name      String     @db.VarChar(120)
  slug      String     @unique @db.VarChar(120)
  imageUrl  String?    @map("image_url")
  parentId  Int?       @map("parent_id")
  isDeleted Boolean    @default(false) @map("is_deleted")
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz

  // Self-relation for subcategories
  parent   Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children Category[] @relation("CategoryToCategory")
  products Product[]

  @@map("categories")
}

// ─── Products ─────────────────────────────────────────────────────────────────
model Product {
  id            Int      @id @default(autoincrement())
  name          String   @db.VarChar(300)
  slug          String   @unique @db.VarChar(300)
  description   String?
  price         Decimal  @db.Decimal(12, 2)
  originalPrice Decimal? @map("original_price") @db.Decimal(12, 2)
  stockQty      Int      @default(0) @map("stock_qty")
  categoryId    Int?     @map("category_id")
  brand         String?  @db.VarChar(100)
  badge         String?  @db.VarChar(50)
  availability  String   @default("in_stock") @db.VarChar(30)
  // 'in_stock' | 'ships_2_3_days' | 'pre_order'
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  category   Category?      @relation(fields: [categoryId], references: [id])
  images     ProductImage[]
  cartItems  CartItem[]
  orderItems OrderItem[]
  wishlist   Wishlist[]
  reviews    Review[]

  @@map("products")
}

// ─── Product Images ───────────────────────────────────────────────────────────
model ProductImage {
  id        Int    @id @default(autoincrement())
  productId Int    @map("product_id")
  url       String
  sortOrder Int    @default(0) @map("sort_order")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

// ─── Cart Items ───────────────────────────────────────────────────────────────
model CartItem {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  productId Int      @map("product_id")
  quantity  Int      @default(1)
  variant   String?  @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("cart_items")
}

// ─── Addresses ────────────────────────────────────────────────────────────────
model Address {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  name         String   @db.VarChar(120)
  phone        String   @db.VarChar(20)
  addressLine1 String   @map("address_line1") @db.VarChar(255)
  addressLine2 String?  @map("address_line2") @db.VarChar(255)
  city         String   @db.VarChar(100)
  postalCode   String?  @map("postal_code") @db.VarChar(20)
  province     String?  @db.VarChar(100)
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("addresses")
}

// ─── Orders ───────────────────────────────────────────────────────────────────
model Order {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  addressId      Int?     @map("address_id")
  status         String   @default("pending") @db.VarChar(30)
  // 'pending' | 'processing' | 'shipped' | 'delivered' | 'cancelled'
  total          Decimal  @db.Decimal(14, 2)
  deliveryFee    Decimal  @default(0) @map("delivery_fee") @db.Decimal(10, 2)
  couponDiscount Decimal  @default(0) @map("coupon_discount") @db.Decimal(10, 2)
  paymentMethod  String   @default("cod") @map("payment_method") @db.VarChar(30)
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user       User        @relation(fields: [userId], references: [id])
  address    Address?    @relation(fields: [addressId], references: [id])
  orderItems OrderItem[]
  payments   Payment[]

  @@map("orders")
}

// ─── Payments ─────────────────────────────────────────────────────────────────
model Payment {
  id               Int      @id @default(autoincrement())
  orderId          Int      @map("order_id")
  paymentMethod    String   @map("payment_method") @db.VarChar(30)
  transactionId    String?  @map("transaction_id") @db.VarChar(100)
  amount           Decimal  @db.Decimal(14, 2)
  currency         String   @default("LKR") @db.VarChar(10)
  status           String   @db.VarChar(30) // 'success' | 'failed' | 'pending'
  payhereStatus    Int?     @map("payhere_status") // status_code from PayHere
  payhereMessage   String?  @map("payhere_message")
  payhereReference String?  @map("payhere_reference") @db.VarChar(100) // payhere_payment_id
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ─── Order Items ──────────────────────────────────────────────────────────────
model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int     @map("order_id")
  productId Int?    @map("product_id")
  name      String  @db.VarChar(300)
  price     Decimal @db.Decimal(12, 2)
  quantity  Int
  imageUrl  String? @map("image_url")
  variant   String? @db.VarChar(100)

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("order_items")
}

// ─── Wishlist ─────────────────────────────────────────────────────────────────
model Wishlist {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  productId Int      @map("product_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("wishlist")
}

// ─── Reviews ──────────────────────────────────────────────────────────────────
model Review {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  productId Int      @map("product_id")
  rating    Int      // 1-5
  comment   String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("reviews")
}
